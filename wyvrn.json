{
  "name": "redis-plus-plus",
  "version": "1.3.15.0",
  "schemaVersion": 2,
  "kind": "StaticLib",
  "description": "Redis C++ client built on hiredis",
  "dependencies": {
    "hiredis": "^1.3.0.0"
  },
  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DREDIS_PLUS_PLUS_BUILD_TEST=OFF",
      "-DREDIS_PLUS_PLUS_USE_TLS=OFF",
      "-DCMAKE_DEBUG_POSTFIX=d",
      "-DCMAKE_RELWITHDEBINFO_POSTFIX=rd",
      "-DCMAKE_MINSIZEREL_POSTFIX=msr"
    ],
    "installDir": "install"
  }
}
